<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>ZyroYonk Hub</title>

<style>
    body {
        margin: 0;
        font-family: Arial, sans-serif;
        background: linear-gradient(135deg, #0d0d0d, #1a001f);
        color: white;
        text-align: center;
    }

    .container {
        max-width: 500px;
        margin: auto;
        padding-top: 60px;
    }

    .logo {
        font-size: 36px;
        font-weight: bold;
        background: linear-gradient(90deg, #8a2bff, #ff00cc);
        -webkit-background-clip: text;
        -webkit-text-fill-color: transparent;
    }

    .subtitle {
        color: #aaa;
        margin-bottom: 30px;
    }

    .card {
        background: rgba(20,20,20,0.9);
        padding: 25px;
        border-radius: 20px;
        box-shadow: 0 0 25px rgba(138,43,255,0.3);
    }

    .btn {
        display: block;
        margin: 12px 0;
        padding: 15px;
        background: #1f1f1f;
        border-radius: 12px;
        text-decoration: none;
        color: white;
        transition: 0.2s;
        font-weight: bold;
    }

    .btn:hover {
        transform: scale(1.05);
        background: #2b2b2b;
    }

    .main-btn {
        background: #8a2bff;
    }

    .main-btn:hover {
        background: #a14bff;
    }

    footer {
        margin-top: 40px;
        color: #555;
        font-size: 12px;
    }
</style>
</head>

<body>

<div class="container">

    <div class="logo">ZyroYonk</div>
    <div class="subtitle">Ultimate Script Hub ⚡</div>

    <div class="card">

        <a href="#" class="btn main-btn" onclick="copyScript()">📋 Copy Script</a>

        <a href="#" class="btn">🔑 Get Key</a>
        <a href="#" class="btn">💬 Discord</a>
        <a href="#" class="btn">📺 YouTube</a>
        <a href="#" class="btn">⬇ Download</a>

    </div>

    <footer>
        © 2026 ZyroYonk Hub
    </footer>

</div>

<script>
function copyScript() {
    const script = `loadstring(game:HttpGet("https://ZyroYonk.github.io/script.lua"))()`;
    navigator.clipboard.writeText(script);
    alert("Script copied to clipboard!");
}
</script>

</body>
</html>
